[Unit]
Description=Yvy Frontend Service
After=network.target yvy-backend.service
Wants=yvy-backend.service

[Service]
Type=simple
User={{ yvy_user }}
Group={{ yvy_group }}
WorkingDirectory={{ app_dir }}
Environment=HOME=/home/{{ yvy_user }}
Environment=YVY_LOCAL_DEV=1
Environment=PORT=5001
Environment=BROWSER=none
ExecStart=/usr/bin/bash {{ app_dir }}/scripts/run-frontend.sh
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
