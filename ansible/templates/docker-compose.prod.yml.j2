# Override para produção na OCI
# Remove bind mounts de desenvolvimento e ajusta recursos

services:
  backend:
    volumes: []  # Remove ./backend:/app (dev only)
    deploy:
      resources:
        limits:
          cpus: '2.0'
          memory: 4G

  mongo:
    deploy:
      resources:
        limits:
          cpus: '1.0'
          memory: 2G

  redis:
    deploy:
      resources:
        limits:
          cpus: '0.5'
          memory: 512M

  frontend:
    deploy:
      resources:
        limits:
          cpus: '0.5'
          memory: 1G
