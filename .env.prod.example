MONGO_ROOT_USERNAME=root
MONGO_ROOT_PASSWORD=replace-with-a-strong-root-password
MONGO_APP_USERNAME=yvy_app
MONGO_APP_PASSWORD=replace-with-a-strong-app-password
MONGO_READONLY_USERNAME=yvy_readonly
