## Example environment variables for Yvy
# Replace values with production-ready secrets or use a secret manager
# DO NOT commit .env to git — use .env.example as template

# ── Auth & Networking ──────────────────────────────────────────────────────
API_KEY=
AUTH_REQUIRED=0
BACKEND_URL=http://127.0.0.1:5000
CORS_ORIGINS=http://localhost:5001,http://127.0.0.1:5001,http://localhost:3000

# ── Database ───────────────────────────────────────────────────────────────
SQLITE_PATH=backend/data/yvy.db

# ── Redis (rate limiting) ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── News — RSS scraper (primary, no API key required) ─────────────────────
# Fetches from OEco, Observatório do Clima, Mongabay Brasil, ClimaInfo,
# Agência Brasil, Envolverde and G1 Meio Ambiente via their RSS feeds.
NEWS_SCRAPER_ENABLED=1
# Fallback threshold: if the scraper returns fewer than this many articles,
# the NewsAPI fallback is also tried (requires NEWS_API_KEY below).
NEWS_SCRAPER_FALLBACK_THRESHOLD=5

# ── News — NewsAPI fallback (optional) ────────────────────────────────────
# Only used when the RSS scraper yields < NEWS_SCRAPER_FALLBACK_THRESHOLD
# articles. Leave blank to rely solely on the RSS scraper.
NEWS_API_KEY=

# ── Fire data (NASA FIRMS) ─────────────────────────────────────────────────
FIRMS_MAP_KEY=
FIRMS_SYNC_INTERVAL_HOURS=4
FIRMS_DAY_RANGE=3

# ── Weather / Air Quality ──────────────────────────────────────────────────
WAQI_TOKEN=

# ── Runtime ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
DEV=0
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# ── STALE (legacy MongoDB — no longer used) ───────────────────────────────
# MONGO_URI=
# MONGO_DATABASE=terrabrasilis_data
# MONGO_ROOT_USERNAME=root
# MONGO_ROOT_PASSWORD=
# MONGO_APP_USERNAME=yvy_app
# MONGO_APP_PASSWORD=
# MONGO_READONLY_USERNAME=yvy_readonly
# MONGO_READONLY_PASSWORD=
